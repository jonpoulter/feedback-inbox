{
  "install": "python3 -m venv .venv && .venv/bin/pip install -e \".[dev]\" && cd frontend && npm install",
  "terminals": [
    {
      "name": "API (uvicorn)",
      "command": ".venv/bin/uvicorn app.main:app --reload --port 8000"
    },
    {
      "name": "UI (vite)",
      "command": "cd frontend && npm run dev"
    }
  ]
}
