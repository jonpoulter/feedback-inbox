# Backend environment variables (copy to .env and adjust as needed).
# All are optional — each falls back to the default shown if unset.

# Database connection URL.
# Default: sqlite:///./feedback.db
DATABASE_URL=sqlite:///./feedback.db

# Comma-separated list of allowed CORS origins.
# Default: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Sentry telemetry. Leave SENTRY_DSN empty to disable Sentry entirely.
# Default: SENTRY_DSN unset (disabled), SENTRY_ENVIRONMENT="demo"
SENTRY_DSN=
SENTRY_ENVIRONMENT=demo
